{
  "expo": {
    "name": "horeca-diagnosis",
    "slug": "horeca-diagnosis",
    "version": "1.0.2",
    "orientation": "portrait",
    "splash": {
      "image": "./assets/images/splash-empty.png",
      "resizeMode": "contain",
      "backgroundColor": "#112677"
    },
    "icon": "./assets/images/app-icon-1024.png",
    "scheme": "horecadiagnosis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "ru.pelby.horecadiagnosis",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "70037d30-2771-4d0c-a3f5-992862a9c546"
      }
    },
    "owner": "pelby"
  }
}
