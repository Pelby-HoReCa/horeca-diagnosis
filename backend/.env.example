DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
PORT=4000

# AI provider: yandex | gigachat | auto
AI_PROVIDER=yandex
AI_TIMEOUT_MS=30000
AI_MAX_HISTORY_MESSAGES=10
AI_MAX_INPUT_CHARS=2000
AI_TEMPERATURE=0.25
AI_MAX_TOKENS=500

# YandexGPT
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Optional override, e.g. gpt://<folderId>/yandexgpt/latest
YANDEX_MODEL_URI=

# GigaChat (optional fallback)
GIGACHAT_ACCESS_TOKEN=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_MODEL=GigaChat-2-Pro

# Phone verification (SMS.ru)
SMSRU_API_ID=
SMSRU_SMS_ENDPOINT=https://sms.ru/sms/send
SMSRU_CALLCHECK_ADD_ENDPOINT=https://sms.ru/callcheck/add
SMSRU_CALLCHECK_STATUS_ENDPOINT=https://sms.ru/callcheck/status
SMSRU_CODE_TEMPLATE=Код Pelby: {code}
# Approved sender name in SMS.ru (recommended to set explicitly in production)
SMSRU_FROM=
PHONE_VERIFICATION_TTL_MS=300000
PHONE_VERIFICATION_MAX_ATTEMPTS=5
PHONE_VERIFICATION_MAX_STARTS_PER_HOUR=10
PHONE_VERIFICATION_MIN_RESTART_INTERVAL_MS=30000
